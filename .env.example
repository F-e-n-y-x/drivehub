# ---------------------------------------------------------------------------
# DriveHub configuration. Copy to ".env" and fill in the required values.
# ---------------------------------------------------------------------------

# --- Required: encrypts stored remote credentials/tokens (AES-256-GCM). ---
# Generate one with:  openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=change-me-to-a-long-random-secret

# --- Required: the URL you reach DriveHub at (also the OAuth redirect host). ---
PUBLIC_URL=http://localhost:8080

# --- Permissions ---
# The uid:gid the app runs as inside the container. Set both to 0 to back up
# root-owned data (e.g. system AppData) and to avoid permission errors on bind
# mounts; otherwise set them to the uid:gid that owns your folders.
PUID=10001
PGID=10001

# --- Optional: only needed for one-click Google Drive sign-in (see SETUP.md). ---
# Other backends (Local, S3, B2, Dropbox/OneDrive, WebDAV, SFTP) are configured
# in the web UI and need none of this.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Optional tuning ---
# Max parallel transfers per job.
CONCURRENCY=4
# Log verbosity: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Path to the rclone binary (the Docker image bundles it; override for bare-metal).
# RCLONE_BIN=/usr/local/bin/rclone

# Inside Docker these default to the mounted volumes; override only for bare-metal.
# DATA_DIR=/data/app
# HUB_PATH=/data/sync
# PORT=8080
