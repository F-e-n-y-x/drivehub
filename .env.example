# ---------------------------------------------------------------------------
# DriveHub configuration. Copy to ".env" and fill in the required values.
# ---------------------------------------------------------------------------

# --- Required: Google OAuth (see SETUP.md for a step-by-step walkthrough) ---
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# --- Required: secret used to encrypt refresh tokens at rest (AES-256-GCM) ---
# Generate one with:  openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=change-me-to-a-long-random-secret

# --- Public URL the browser reaches this app at. ---
# This host MUST match the "Authorized redirect URI" you set in Google Cloud:
#   <PUBLIC_URL>/api/auth/google/callback
PUBLIC_URL=http://localhost:8080

# --- Optional tuning ---
# How often (ms) to poll each Google account's changes feed.
POLL_INTERVAL_MS=7000
# Max parallel transfers.
CONCURRENCY=4
# If false, deleting a file locally will NOT delete it from Drive (additive-only).
DELETE_PROPAGATION=true
# Log verbosity: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Inside Docker these default to the mounted volumes; override only for bare-metal.
# HUB_PATH=/data/sync
# DATA_DIR=/data/app
# PORT=8080
