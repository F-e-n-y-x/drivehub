    "chokidar": "^4.0.3",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.0",
    "googleapis": "^144.0.0",
    "nanoid": "^5.0.9",
    "p-limit": "^6.2.0",
    "pino": "^9.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "drizzle-kit": "^0.30.1",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
